generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  Org_Admin
  User
  Admin
}

model Org {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  profile     OrgProfile?  @relation("OrgToProfile")
  payrollRuns PayrollRun[]
}

model OrgProfile {
  id              String   @id @default(uuid())
  orgId           String   @unique
  org             Org      @relation("OrgToProfile",fields: [orgId], references: [id], onDelete: Cascade)

  // Basic Information
  phone           String?
  website         String?
  logo            String?  // URL to logo image
  description     String?  @db.Text

  // Company Details
  industry        String?
  companySize     String?
  foundedYear     String?
  registrationNumber String?

  // Address Information
  address         String?
  city            String?
  state           String?
  pincode         String?
  country         String   @default("India")
  officeLocations  String[]

  // Tax & Legal Information
  pan             String?
  gst             String?
  taxId           String?

  // Banking Information
  bankName        String?
  accountNumber   String?
  ifscCode        String?

  // Payroll & Financial Settings
  currency        String   @default("INR")
  timezone        String   @default("Asia/Kolkata")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payrollSettings PayrollSettings[]

  @@index([orgId])
}

model User {
  id              String   @id @default(uuid())
  email           String
  password        String
  name            String?
  role            Role     @default(User)
  designation     String   @default("Not Specified")
  dateOfJoining   String?
  ctc             Int?    @default(0)

  active          Boolean  @default(false)

  orgId           String
  org             Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdBy       String?  // who created this user (org admin id)
  updatedBy       String?  // who updated this user (org admin id)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payrollEntries  PayrollRunEntry[]

  @@unique([email, orgId])
  @@index([orgId])
  @@index([designation])
}

enum PayrollCycle {
  monthly
  biweekly
  weekly
}

enum OvertimeCalculation {
  hourly
  daily
}

enum PayrollStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  EXPIRED
}

model PayrollSettings {
  id              String   @id @default(uuid())

  orgProfileId    String
  orgProfile      OrgProfile @relation(fields: [orgProfileId], references: [id], onDelete: Cascade)

  // Version Tracking
  version         Int      @default(1)
  effectiveFrom   DateTime
  effectiveTo     DateTime?

  // Payroll Cycle Configuration
  payrollCycle    PayrollCycle @default(monthly)
  cycleConfig     Json
  workingDaysPerMonth Int  @default(26)
  weekendDays     String[] @default(["Saturday", "Sunday"])

  // Salary Structure
  basicPercent     Float   @default(50.0)
  hraPercent       Float   @default(40.0)
  allowancePercent Float   @default(10.0)

  // Overtime
  overtimeEnabled  Boolean @default(true)
  overtimeRate     Float   @default(1.5)
  overtimeCalculation OvertimeCalculation @default(hourly)

  // PF
  pfEnabled        Boolean @default(true)
  pfPercent        Float   @default(12.0)
  pfEmployerContribution Float @default(12.0)
  pfCeiling        Int     @default(15000)

  // ESI
  esiEnabled       Boolean @default(true)
  esiPercent       Float   @default(0.75)
  esiEmployerPercent Float @default(3.25)
  esiCeiling       Int     @default(21000)

  // Gratuity
  gratuityEnabled  Boolean @default(true)
  gratuityYears    Int     @default(5)

  // Professional Tax
  professionalTaxEnabled Boolean @default(true)
  professionalTaxAmount  Int     @default(200)

  // TDS
  tdsEnabled       Boolean @default(true)

  // Bonus
  bonusEnabled     Boolean @default(true)
  bonusMonth       String  @default("March")
  performanceBonusEnabled Boolean @default(true)

  // Leave Encashment
  leaveEncashmentEnabled Boolean @default(true)
  maxEncashmentDays Int   @default(30)

  // Loan & Advance
  loanEnabled      Boolean @default(true)
  maxLoanAmount    Int     @default(100000)
  advanceEnabled   Boolean @default(true)
  maxAdvanceAmount Int     @default(50000)

  status           PayrollStatus @default(DRAFT)
  isLocked         Boolean @default(false)

  createdBy       String?
  updatedBy       String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  payrollRuns      PayrollRun[]

  @@index([orgProfileId])
  @@unique([orgProfileId, version])
}

enum TaxRegime {
  old
  new
}

model IncomeTaxSetting {
  id                String   @id @default(uuid())
  financialYear     String
  regime            TaxRegime

  standardDeduction Float
  cessPercentage    Float

  slabs             IncomeTaxSlab[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([financialYear, regime])
}

model IncomeTaxSlab {
  id            String   @id @default(uuid())

  settingId     String
  setting       IncomeTaxSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)

  minIncome     Float
  maxIncome     Float?
  rate          Float

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum PayrollRunStatus {
  DRAFT
  PROCESSING
  COMPLETED
  FAILED
}

model PayrollRun {
  id                String           @id @default(uuid())

  orgId             String
  org               Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)

  payrollSettingsId String
  payrollSettings   PayrollSettings  @relation(fields: [payrollSettingsId], references: [id])

  // Which month this run covers e.g. "2026-04"
  month             String

  status            PayrollRunStatus @default(DRAFT)

  // Aggregated totals (filled once COMPLETED)
  totalEmployees    Int              @default(0)
  totalGross        Float            @default(0)
  totalDeductions   Float            @default(0)
  totalNet          Float            @default(0)

  // Who triggered the run
  runBy             String?

  // Error message if status = FAILED
  errorMessage      String?          @db.Text

  entries           PayrollRunEntry[]

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([orgId, month])
  @@index([orgId])
  @@index([status])
}

model PayrollRunEntry {
  id              String      @id @default(uuid())

  payrollRunId    String
  payrollRun      PayrollRun  @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Snapshot of employee details at time of run
  employeeName    String
  designation     String
  ctc             Float

  // Gross earnings breakdown
  grossSalary     Float
  basic           Float
  hra             Float
  allowance       Float

  // Employer-side contributions (cost to company, not deducted from employee)
  pfEmployer      Float       @default(0)
  esiEmployer     Float       @default(0)

  // Employee-side deductions
  pfEmployee      Float       @default(0)
  esiEmployee     Float       @default(0)
  professionalTax Float       @default(0)
  tds             Float       @default(0)
  loanDeduction   Float       @default(0)
  advanceDeduction Float      @default(0)
  otherDeductions Float       @default(0)

  totalDeductions Float       @default(0)

  // Additions
  overtimeAmount  Float       @default(0)
  bonusAmount     Float       @default(0)

  netPay          Float

  // Full calculation detail snapshot for payslip generation
  breakdown       Json?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([payrollRunId, userId])
  @@index([payrollRunId])
  @@index([userId])
}